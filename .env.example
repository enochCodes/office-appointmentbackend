# PostgreSQL connection URL
# Example: postgresql://user:password@localhost:5432/mydb?schema=public
DATABASE_URL="postgresql://your_db_user:your_db_password@localhost:5432/your_database_name?schema=public"

# JWT Secret Key
JWT_SECRET="replace_this_with_a_strong_random_secret_key"

# Server Port
PORT="3000"
EOF
